   "source": [
    "# VideoKit - 通用视频处理工具 (Colab 版)\n",
    "\n",
    "在Google Colab上运行VideoKit，使用免费GPU加速处理。\n",
    "\n",
    "## 使用说明\n",
    "\n",
    "1. 首先确保运行时类型为 GPU: **Runtime -> Change runtime type -> Hardware accelerator -> GPU**\n",
    "2. 按顺序运行以下单元格\n",
    "3. 最后点击生成的公网链接即可使用Web界面\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "setup_env"
   },
   "outputs": [],
   "source": [
    "# ==============================\n",
    "# 第1步：环境检查与系统依赖安装\n",
    "# ==============================\n",
    "\n",
    "import os\n",
    "import sys\n",
    "import subprocess\n",
    "\n",
    "print("=" * 50)\n",
    "print("VideoKit 环境检查")\n",
    "print("=" * 50)\n",
    "\n",
    "# 检查GPU\n",
    "import torch\n",
    "print(f"PyTorch: {torch.__version__}")\n",
    "print(f"GPU可用: {torch.cuda.is_available()}")\n",
    "if torch.cuda.is_available():\n",
    "    print(f"GPU型号: {torch.cuda.get_device_name(0)}")\n",
    "    print(f"GPU显存: {torch.cuda.get_device_properties(0).total_memory / 1024**3:.1f} GB")\n",
    "\n",
    "# 安装系统依赖\n",
    "print("\\n安装系统依赖...")\n",
    "!apt-get update -qq 2>&1 | tail -1\n",
    "!apt-get install -y -qq ffmpeg curl wget git > /dev/null 2>&1\n",
    "print("系统依赖安装完成")\n",
    "\n",
    "# 创建工作目录\n",
    "WORK_DIR = "/content/videokit_workspace"\n",
    "os.makedirs(WORK_DIR, exist_ok=True)\n",
    "os.chdir(WORK_DIR)\n",
    "print(f"工作目录: {WORK_DIR}")"
   ]
