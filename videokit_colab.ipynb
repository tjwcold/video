    "# ==============================\n",
    "# 第5步：启动 VideoKit Web UI\n",
    "# ==============================\n",
    "\n",
    "import os\n",
    "import sys\n",
    "\n",
    "WORK_DIR = "/content/videokit_workspace"\n",
    "os.chdir(WORK_DIR)\n",
    "sys.path.insert(0, WORK_DIR)\n",
    "\n",
    "os.environ['OMP_NUM_THREADS'] = '1'\n",
    "os.environ['GRADIO_ANALYTICS_ENABLED'] = '0'\n",
    "\n",
    "# 直接启动（使用Gradio的share功能获取公网链接）\n",
    "!python videokit.py run \\\n",
    "    --execution-providers cuda \\\n",
    "    --execution-device-ids 0 \\\n",
    "    --execution-thread-count 8 \\\n",
    "    --video-memory-strategy strict \\\n",
    "    --open-browser false \\\n",
    "    --log-level info"
   ]
